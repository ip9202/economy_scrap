# ECOS API Configuration
# Get your API key from: https://ecos.bok.or.kr/api/
ECOS_API_KEY=your_api_key_here

# Pipeline Configuration
MONTHS_BACK=6
EVENT_WINDOW_DAYS=14

# News Query Configuration
QUERIES=["한국은행 기준금리", "통화정책", "금리"]

# Stance Scoring Words
HAWK_WORDS=["인상", "긴축", "물가압력", "과열", "억제", "경계", "매파"]
DOVE_WORDS=["인하", "완화", "둔화", "부양", "하방", "지원", "비둘기"]

# Data Collection Limits
MAX_ITEMS_PER_QUERY=100

# ==============================================================================
# GDELT BigQuery Configuration (Historical News Data)
# ==============================================================================

# Enable/disable GDELT integration
# - true: Use GDELT for historical data (before GDELT_CUTOFF_DATE)
# - false: Use RSS-only mode (2-4 weeks coverage only)
ENABLE_GDELT=true

# Use public BigQuery dataset (free, no account required)
# - true: Use public dataset (1TB/month free tier, no setup required)
# - false: Use authenticated access with your Google Cloud project
GDELT_USE_PUBLIC=true

# Google Cloud Project ID (optional, for authenticated access)
# Only needed if GDELT_USE_PUBLIC=false
# Get your project ID from: https://console.cloud.google.com/
GDELT_PROJECT_ID=

# Date cutoff for switching between GDELT and RSS
# - Before this date: Use GDELT BigQuery (historical backfill)
# - On/after this date: Use Google News RSS (current data)
GDELT_CUTOFF_DATE=2025-08-01

# ==============================================================================
# Google Cloud Credentials (Optional - for authenticated access)
# ==============================================================================

# Path to Google Cloud service account key file
# Only needed if using authenticated access (GDELT_USE_PUBLIC=false)
# See: GDELT_SETUP.md for setup instructions
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json
